# ── App Config ────────────────────────────────────────────────────
# Generate a secret key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# App name shown in UI and emails
APP_NAME=Baseline

# Support email shown in footer
SUPPORT_EMAIL=support@example.com

# Flask environment: "production" or "development"
FLASK_ENV=development

# Enable debug mode (dev only)
FLASK_DEBUG=0

# Port to run on (default 5000)
PORT=5002

# ── Email (Resend) ───────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
# Leave blank to skip emails (they'll be logged to console instead)
RESEND_API_KEY=
EMAIL_FROM=MyApp <noreply@example.com>
